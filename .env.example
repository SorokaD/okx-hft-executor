# Runtime
OKX_HFT_ENV=development
OKX_HFT_RUNTIME_MODE=paper
OKX_HFT_LOG_LEVEL=INFO
OKX_HFT_METRICS_ENABLED=0
OKX_HFT_SAFE_MODE=1

# OKX demo credentials
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=
OKX_FLAG_DEMO=1
OKX_BASE_URL=https://www.okx.com
OKX_ENABLE_REAL_OKX_IN_PAPER=0

# Trading instrument / order params (baseline v1)
OKX_INST_ID=BTC-USDT-SWAP
OKX_TD_MODE=cross
OKX_ORD_TYPE=market
OKX_ORDER_SIZE=1

# Loop / local storage
OKX_LOOP_SLEEP_SEC=1
OKX_SQLITE_PATH=data/baseline_mvp.sqlite3

# Control plane (optional)
OKX_HFT_CONTROL_HOST=127.0.0.1
OKX_HFT_CONTROL_PORT=8080
