# Runtime
OKX_HFT_ENV=development
OKX_HFT_RUNTIME_MODE=paper

# OKX API (live / paper credentials — never commit real secrets)
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=
OKX_FLAG_DEMO=1

# Control plane (optional)
OKX_HFT_CONTROL_HOST=127.0.0.1
OKX_HFT_CONTROL_PORT=8080

# Observability
OKX_HFT_LOG_LEVEL=INFO
OKX_HFT_METRICS_ENABLED=0
